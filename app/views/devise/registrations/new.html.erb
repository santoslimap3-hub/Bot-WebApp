<div class="auth-page">
    <div class="auth-container">
        <div class="auth-brand">
            <div class="auth-brand-icon">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <h1>Create account</h1>
            <p>Get started with your trading dashboard</p>
        </div>

        <div class="auth-card">
            <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
                <%= render "devise/shared/error_messages", resource: resource %>

                <label class="auth-label">Email</label>
                <%= f.email_field :email,
                    autofocus: true,
                    autocomplete: "email",
                    class: "auth-input",
                    placeholder: "you@example.com" %>

                <label class="auth-label">Password</label>
                <% if @minimum_password_length %>
                    <span style="font-size: 0.72rem; color: var(--text-muted); margin-bottom: 6px; display: block;">(<%= @minimum_password_length %> characters minimum)</span>
                <% end %>
                <%= f.password_field :password,
                    autocomplete: "new-password",
                    class: "auth-input",
                    placeholder: "Min 6 characters" %>

                <label class="auth-label">Confirm Password</label>
                <%= f.password_field :password_confirmation,
                    autocomplete: "new-password",
                    class: "auth-input",
                    placeholder: "••••••••" %>

                <%= f.submit "Create account", class: "auth-submit" %>
            <% end %>

            <div class="auth-links">
                <p><%= link_to "Already have an account? Sign in", new_session_path(resource_name), class: "auth-footer-link" %></p>
            </div>
        </div>
    </div>
</div>
