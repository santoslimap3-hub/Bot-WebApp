<div class="auth-page">
    <div class="auth-container" data-controller="toggle-form">
        <div class="auth-brand">
            <div class="auth-brand-icon">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <h1 data-toggle-form-target="loginTitle">Welcome back</h1>
            <p data-toggle-form-target="loginSubtitle">Sign in to your account</p>
            <h1 data-toggle-form-target="signupTitle" class="d-none">Create account</h1>
            <p data-toggle-form-target="signupSubtitle" class="d-none">Get started with your trading dashboard</p>
        </div>

        <div class="auth-card">
                <%# ── Sign In Form ── %>
                <div data-toggle-form-target="loginCard">
                    <%= form_with url: "/login" do |form| %>
                        <label class="auth-label">Email</label>
                        <%= form.text_field :email,
                            data: { toggle_form_target: "email", action: "input->toggle-form#checkFields" },
                            class: "auth-input",
                            placeholder: "you@example.com",
                            autocomplete: "email" %>

                        <label class="auth-label">Password</label>
                        <%= form.password_field :password,
                            data: { toggle_form_target: "password", action: "input->toggle-form#checkFields" },
                            class: "auth-input",
                            placeholder: "••••••••",
                            autocomplete: "current-password" %>

                        <%= form.submit "Sign in",
                            data: { toggle_form_target: "signInButton" },
                            disabled: true,
                            class: "auth-submit" %>
                    <% end %>

                    <div class="auth-footer">
                        <p>Don't have an account?</p>
                        <button type="button" class="auth-footer-link" data-action="click->toggle-form#toggle">Create one</button>
                    </div>
                </div>

                <%# ── Sign Up Form ── %>
                <div data-toggle-form-target="signupCard" class="d-none">
                    <%= form_with url: "/signup" do |form| %>
                        <label class="auth-label">Email</label>
                        <%= form.text_field :email,
                            data: { toggle_form_target: "signUpEmail", action: "input->toggle-form#checkFields" },
                            class: "auth-input",
                            placeholder: "you@example.com",
                            autocomplete: "email" %>

                        <label class="auth-label">Password</label>
                        <%= form.password_field :password,
                            data: { toggle_form_target: "signUpPassword", action: "input->toggle-form#checkFields" },
                            class: "auth-input",
                            placeholder: "Min 6 characters",
                            autocomplete: "new-password" %>

                        <label class="auth-label">Confirm Password</label>
                        <%= form.password_field :password_confirmation,
                            data: { toggle_form_target: "signUpPasswordConfirmation", action: "input->toggle-form#checkFields" },
                            class: "auth-input",
                            placeholder: "••••••••",
                            autocomplete: "new-password" %>

                        <%= form.submit "Create account",
                            data: { toggle_form_target: "signupButton" },
                            disabled: true,
                            class: "auth-submit" %>
                    <% end %>

                    <div class="auth-footer">
                        <p>Already have an account?</p>
                        <button type="button" class="auth-footer-link" data-action="click->toggle-form#toggle">Sign in</button>
                    </div>
                </div>

            <% if flash[:alert] %>
                <div class="auth-alert auth-alert-danger">
                    <i class="bi bi-exclamation-circle me-2"></i><%= flash[:alert] %>
                </div>
            <% end %>
            <% if flash[:notice] %>
                <div class="auth-alert auth-alert-success">
                    <i class="bi bi-check-circle me-2"></i><%= flash[:notice] %>
                </div>
            <% end %>
        </div>
    </div>
</div>