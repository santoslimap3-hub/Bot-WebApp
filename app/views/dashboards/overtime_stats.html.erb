<div class="d-flex align-items-stretch" data-controller="overtime-stats" data-trades="<%= @all_trades.to_json %>">
    <div><%= render 'shared/sidebar' %></div>

    <div class="flex-grow-1 p-4" style="min-height: 100vh; background: var(--bg-base);">

        <div class="mb-4">
            <h4 style="color: var(--text-primary); font-weight: 700;">Overtime Stats</h4>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0;">Historical performance overview</p>
        </div>

        <%# Cumulative P&L chart %>
        <div class="dark-card mb-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <span style="font-size: 0.9rem; font-weight: 600; color: var(--text-primary);">Cumulative P&amp;L</span>
            </div>

            <div class="d-flex align-items-center flex-wrap gap-1 mb-3">
                <% [["All time", 0], ["30d", 30], ["14d", 14], ["7d", 7], ["5d", 5], ["4d", 4], ["3d", 3], ["2d", 2], ["1d", 1]].each do |label, days| %>
                    <button type="button" class="filter-btn"
                            data-action="click->overtime-stats#filterDays"
                            data-overtime-stats-days-param="<%= days %>"><%= label %></button>
                <% end %>

                <div class="d-flex align-items-center gap-1 ms-2">
                    <span style="font-size: 0.75rem; color: var(--text-muted);">Custom:</span>
                    <input type="date" class="dark-input form-control form-control-sm" style="width: 135px;"
                           data-overtime-stats-target="customFrom">
                    <span style="color: var(--text-muted);">–</span>
                    <input type="date" class="dark-input form-control form-control-sm" style="width: 135px;"
                           data-overtime-stats-target="customTo">
                    <button type="button" class="btn-accent"
                            data-action="click->overtime-stats#applyCustom">Apply</button>
                </div>
            </div>

            <canvas data-overtime-stats-target="canvas"></canvas>
        </div>

        <%# Daily P&L chart %>
        <div class="dark-card mb-4">
            <div class="mb-3">
                <span style="font-size: 0.9rem; font-weight: 600; color: var(--text-primary);">Daily P&amp;L</span>
            </div>
            <canvas data-overtime-stats-target="barCanvas"></canvas>
        </div>

        <%# Trade history table %>
        <div class="dark-card p-0" style="overflow: hidden;">

            <div class="d-flex align-items-center justify-content-between px-4 py-3"
                 style="border-bottom: 1px solid var(--border);">
                <span style="font-size: 0.9rem; font-weight: 600; color: var(--text-primary);">Trade History</span>
            </div>

            <table class="dark-table">
                <thead>
                    <tr>
                        <th>Open Time</th>
                        <th>Direction</th>
                        <th>Symbol</th>
                        <th>Profit</th>
                    </tr>
                </thead>
                <tbody data-overtime-stats-target="tradeTable">
                </tbody>
            </table>

        </div>

    </div>
</div>
