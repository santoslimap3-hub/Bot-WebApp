<div class="d-flex align-items-stretch" data-controller="dashboard">

    <div><%= render 'shared/sidebar' %></div>

    <div class="flex-grow-1 p-4" style="min-height: 100vh; background: var(--bg-base);">

        <div class="mb-4">
            <h4 style="color: var(--text-primary); font-weight: 700;">Dashboard</h4>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0;">Last 24 hours overview</p>
        </div>

        <div class="row g-4 mb-4">

            <div class="col-md-4">
                <div class="dark-card h-100">
                    <h6>Net Profit (All Time)</h6>
                    <div class="big-value <%= @net_profit >= 0 ? 'profit' : 'loss' %>">
                        $<%= @net_profit %>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="dark-card h-100">
                    <h6>Warnings</h6>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0;">No warnings detected</p>
                </div>
            </div>

        </div>

        <div class="dark-card p-0" style="overflow: hidden;">

            <div class="d-flex align-items-center justify-content-between px-4 py-3"
                 style="border-bottom: 1px solid var(--border);">
                <span style="font-size: 0.9rem; font-weight: 600; color: var(--text-primary);">Recent Trades</span>
                <span style="font-size: 0.75rem; color: var(--text-muted);">Last 24h</span>
            </div>

            <table class="dark-table">
                <thead>
                    <tr>
                        <th>Open Time</th>
                        <th>Direction</th>
                        <th>Symbol</th>
                        <th>Profit</th>
                    </tr>
                </thead>
                <tbody>
                    <% @recent_trades.each do |trade| %>
                        <tr>
                            <td style="color: var(--text-muted);">
                                <%= trade.open_time.strftime("%H:%M %d %b") %>
                            </td>
                            <td>
                                <span class="<%= trade.direction == 'BUY' ? 'badge-buy' : 'badge-sell' %>">
                                    <%= trade.direction %>
                                </span>
                            </td>
                            <td style="font-weight: 600;"><%= trade.symbol %></td>
                            <td class="<%= trade.net_profit >= 0 ? 'profit' : 'loss' %> fw-semibold">
                                $<%= trade.net_profit %>
                            </td>
                        </tr>
                    <% end %>
                </tbody>
            </table>

        </div>

    </div>

</div>
