<div class="sidebar d-flex flex-column align-items-center py-3" style="width: 80px; min-height: 100vh; position: sticky; top: 0;">

    <a href="/" class="text-decoration-none mb-4">
        <span style="width:36px; height:36px; background: rgba(0,0,0,0.2); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:16px;">⚡</span>
    </a>

    <hr class="dark-hr w-100 mt-0 mb-3">

    <ul class="nav flex-column align-items-center gap-2 mb-auto w-100">
        <li class="nav-item w-100 text-center">
            <%= link_to dashboard_path, class: "nav-link d-flex flex-column align-items-center gap-1", style: "font-size: 0.6rem; padding: 8px 4px;" do %>
                <span style="font-size: 1.1rem;">📊</span>
                Dashboard
            <% end %>
        </li>
        <li class="nav-item w-100 text-center">
            <%= link_to overtime_stats_path, class: "nav-link d-flex flex-column align-items-center gap-1", style: "font-size: 0.6rem; padding: 8px 4px;" do %>
                <span style="font-size: 1.1rem;">📈</span>
                Stats
            <% end %>
        </li>
        <li class="nav-item w-100 text-center">
            <%= link_to trade_outcomes_path, class: "nav-link d-flex flex-column align-items-center gap-1", style: "font-size: 0.6rem; padding: 8px 4px;" do %>
                <span style="font-size: 1.1rem;">📈</span>
                trade outcomes overview
            <% end %>
        </li>
    </ul>

    <hr class="dark-hr w-100 mb-2">

    <%= button_to destroy_user_session_path, method: :delete, class: "btn-logout", style: "font-size: 0.6rem; padding: 4px 6px;" do %>
        Out
    <% end %>

</div>
